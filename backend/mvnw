# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.3.2
# ----------------------------------------------------------------------------

# If MVNW_REPOURL is empty, use Maven Central
if [ -z "$MVNW_REPOURL" ]; then
  MVNW_REPOURL="https://repo.maven.apache.org/maven2"
fi

WRAPPER_JAR="$(MAVEN_PROJECTBASEDIR=. pwd)/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_LAUNCHER=org.apache.maven.wrapper.MavenWrapperMain

downloadMavenWrapper() {
  jarUrl="$MVNW_REPOURL/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar"
  while IFS="=" read key value; do
    case "$key" in (wrapperUrl) jarUrl="$value"; break ;;
    esac
  done < .mvn/wrapper/maven-wrapper.properties
  echo "Downloading from $jarUrl"
  if command -v curl > /dev/null 2>&1; then
    curl -fsSL -o "$WRAPPER_JAR" "$jarUrl"
  elif command -v wget > /dev/null 2>&1; then
    wget -q -O "$WRAPPER_JAR" "$jarUrl"
  fi
}

if [ ! -f "$WRAPPER_JAR" ]; then
  downloadMavenWrapper
fi

exec java $MAVEN_OPTS -classpath "$WRAPPER_JAR" $JVMFLAGS $WRAPPER_LAUNCHER "$@"
